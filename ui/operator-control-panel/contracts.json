  "futureIntentEndpoints": {
    "/operator/intent/paper/start": {
      "status": "server_authorized_for_bounded_paper_only",
      "required_body": {
        "mode": "PAPER",
        "profile": "PAPER_EXPLORATION_ALPHA",
        "duration_seconds": "one of allowed durations",
        "watchlist": ["BTC/USD", "ETH/USD", "SOL/USD"],
        "approve_autonomous_paper": true,
        "real_money": false,
        "live": false
      },
      "refusals": [
        "AUTONOMOUS_PAPER_APPROVAL_REQUIRED",
        "DUPLICATE_ACTIVE_RUN",
        "LIVE_NOT_APPROVED",
        "REAL_MONEY_NOT_APPROVED",
        "UNSUPPORTED_PAPER_PROFILE",
        "UNSUPPORTED_WATCHLIST_SYMBOL",
        "UNSUPPORTED_DURATION_SECONDS"
      ]
    },
    "/operator/intent/paper/stop": {
      "status": "server_authorized_graceful_stop_request",
      "does_not_call_broker": true,
      "does_not_flatten_positions": true,
      "refusals": [
        "NO_ACTIVE_RUN",
        "SAFE_STOP_UNAVAILABLE_NON_WINDOWS",
        "GRACEFUL_STOP_SIGNAL_FAILED"
      ]
    },
    "/operator/intent/snapshot/export": "disabled/refused until export authority is implemented",
    "/operator/intent/world-awareness/poll": {
      "status": "server_authorized_read_only_external_feed_poll",
      "required_body": {
        "provider": "alpaca_news",
        "symbols": ["BTC/USD", "ETH/USD", "SOL/USD"],
        "limit": 25,
        "force": false
      },
      "does_not_call_broker": true,
      "does_not_trade": true,
      "does_not_change_decisionframe_score": true,
      "refusals": [
        "FEED_DISABLED",
        "CREDENTIAL_MISSING",
        "UNKNOWN_PROVIDER",
        "PROVIDER_NOT_DUE",
        "PROVIDER_ADAPTER_MISSING"
      ]
    },
    "/operator/intent/live/request-enable": "LIVE_NOT_APPROVED",
    "/operator/intent/live/start": "LIVE_NOT_APPROVED",
    "/operator/intent/emergency-stop": "disabled/refused until governed emergency authority is implemented"
  },
  "intentRules": {
    "validate_authority_server_side": true,
    "emit_audit_event": true,
    "return_allow_or_refuse": true,
    "include_refusal_reason": true,
    "never_bypass_engine": true,
    "never_call_broker_directly_from_ui": true
  }
