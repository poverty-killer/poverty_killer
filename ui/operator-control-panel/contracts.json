{
  "version": "phase-4-readonly-backend-ready",
  "mode": "read_only_operator_contracts",
  "ui_policy": {
    "paper_enabled_first": true,
    "live_visible_but_locked": true,
    "manual_trading_available": false,
    "force_trade_available": false,
    "ui_is_trading_engine": false,
    "server_authority_required": true,
    "broker_direct_calls_from_ui": false
  },
  "data_source_labels": [
    "MOCK_DATA",
    "READ_ONLY_BACKEND"
  ],
  "readOnlyEndpoints": {
    "/operator/status": {
      "api_version": "operator-readonly-v1",
      "data_source": "READ_ONLY_BACKEND",
      "bot_status": "RUNNING | NO_ACTIVE_RUNTIME_ATTACHED | DEGRADED | BLOCKED",
      "runtime_mode": "PAPER | SHADOW | BACKTEST | LIVE_DISABLED",
      "mode_state": "PAPER_ENABLED | LIVE_LOCKED",
      "capability_state": "PAPER_ENABLED",
      "active_profile": "PAPER_EXPLORATION_ALPHA | DEFAULT | UNKNOWN_NO_ACTIVE_RUNTIME",
      "broker": "alpaca_paper | UNKNOWN_NO_ACTIVE_RUNTIME",
      "endpoint": "paper endpoint or unknown",
      "market_data": "provider id or unknown",
      "universe": ["BTC/USD", "ETH/USD", "SOL/USD"],
      "asset_classes": ["crypto"],
      "last_heartbeat_ts": "ISO-8601 or null",
      "dominant_blocker": "reason code",
      "safety_verdict": "CLEAN | DEGRADED | BLOCKED | READ_ONLY_BACKEND_IDLE",
      "live_blocked": true,
      "real_money_blocked": true,
      "broker_post_count": 0,
      "broker_delete_count": 0,
      "mutation_authorized_count": 0,
      "manual_trading_available": false,
      "force_trade_available": false
    },
    "/operator/runtime": {
      "process_state": "RUNNING | STOPPED | NO_ACTIVE_RUNTIME_ATTACHED",
      "launch_command": "redacted command or null",
      "duration_seconds": 0,
      "started_at": "ISO-8601 or null",
      "shutdown_reason": "reason code or null",
      "bounded_timer_started": true,
      "bounded_duration_elapsed": true,
      "runtime_commit": "git sha or null",
      "supervisor_state": "future supervisor state",
      "duplicate_run_prevention": "future duplicate-run policy"
    },
    "/operator/profile": {
      "active_threshold_profile": "PAPER_EXPLORATION_ALPHA | DEFAULT | UNKNOWN_NO_ACTIVE_RUNTIME",
      "paper_exploration_alpha_active": true,
      "paper_only": true,
      "activation_status": "PASS | REFUSED | NO_ACTIVE_RUNTIME_ATTACHED",
      "activation_refusal_reason": "reason code or null"
    },
    "/operator/universe": {
      "symbols": ["BTC/USD", "ETH/USD", "SOL/USD"],
      "asset_classes": ["crypto"],
      "venues": ["alpaca", "kraken"],
      "runtime_watchlist": ["BTC/USD", "ETH/USD", "SOL/USD"],
      "universe_source": "CONFIG_EXPLICIT_ALLOWED:runtime_watchlist",
      "excluded_symbols": [],
      "exclusion_reason_codes": []
    },
    "/operator/readiness/live": {
      "live_status": "LIVE_LOCKED | LIVE_READINESS_PENDING | LIVE_READY_BUT_DISABLED | LIVE_ENABLED",
      "refusal_reason": "LIVE_NOT_APPROVED",
      "broker_endpoint_authority": "PAPER_ONLY_FOR_CURRENT_OPERATOR_API",
      "credential_authority": "present/not present only; no secrets",
      "real_money_authority": "BLOCKED",
      "physical_fuse": "required status",
      "risk_governor_status": "required status",
      "account_status": "required status",
      "position_reconciliation": "required status",
      "order_reconciliation": "required status",
      "fill_ledger_health": "required status",
      "tca_status": "required status",
      "market_truth_health": "required status",
      "kill_switch_status": "required status",
      "audit_logging_status": "required status",
      "operator_approval_status": "NOT_APPROVED",
      "dirty_worktree_warning": "clean/dirty/unknown",
      "current_git_commit": "git sha or unknown",
      "pushed_commit_match": "true/false/unknown",
      "missing_prerequisites": [],
      "passed_prerequisites": [],
      "authority_chain": [],
      "last_live_readiness_audit": "ISO-8601 or null"
    },
    "/operator/diagnostics": {
      "api_version": "operator-readonly-v1",
      "data_source": "READ_ONLY_BACKEND",
      "git_commit": "sha or unknown",
      "dirty_worktree": "clean/dirty/unknown",
      "python_version": "version or unknown",
      "credentials_present": "present/not present only; no secret values",
      "logs": "status only",
      "db": "status only",
      "legacy_dashboard_command_routes_present": true,
      "legacy_dashboard_reuse_allowed": false
    },
    "/operator/orders-summary": {
      "source": "broker_confirmed | no_active_runtime",
      "broker_confirmed_open_orders": 0,
      "local_open_without_broker_match_count": 0,
      "terminal_orders": 0,
      "reconciliation_conflicts": 0,
      "broker_truth_canonical": true
    },
    "/operator/fills-summary": {
      "source": "broker_confirmed | no_active_runtime",
      "local_fills": 0,
      "broker_fill_ledger_rows": 0,
      "fill_hydration_count": 0,
      "fill_hydration_missing_count": 0,
      "fill_hydration_conflict_count": 0,
      "fake_fills_allowed": false
    },
    "/operator/tca-summary": {
      "source": "broker_confirmed_when_available | no_active_runtime",
      "tca_records_count": 0,
      "tca_unknown_count": 0,
      "execution_quality_verdict": "UNKNOWN_INSUFFICIENT_BROKER_DETAIL | UNKNOWN_NO_ACTIVE_RUNTIME",
      "fake_fees_allowed": false,
      "fake_tca_allowed": false
    },
    "/operator/audit-summary": {
      "source": "audit_log | no_active_runtime",
      "operator_action_count": 0,
      "broker_mutation_count": 0,
      "live_refusal_count": 0,
      "last_event": null
    },
    "/operator/contracts": {
      "version": "operator-readonly-v1",
      "read_only": true,
      "truth_labels": {
        "broker_confirmed": "canonical after broker acknowledgement/reconciliation",
        "local_diagnostic": "diagnostic only",
        "estimated": "non-authoritative estimate",
        "unknown": "unavailable; not invented"
      }
    }
  },
  "futureIntentEndpoints": {
    "/operator/intent/paper/start": "disabled/refused until supervisor authority is implemented",
    "/operator/intent/paper/stop": "disabled/refused until supervisor authority is implemented",
    "/operator/intent/snapshot/export": "disabled/refused until export authority is implemented",
    "/operator/intent/live/request-enable": "LIVE_NOT_APPROVED",
    "/operator/intent/live/start": "LIVE_NOT_APPROVED",
    "/operator/intent/emergency-stop": "disabled/refused until governed emergency authority is implemented"
  },
  "intentRules": {
    "validate_authority_server_side": true,
    "emit_audit_event": true,
    "return_allow_or_refuse": true,
    "include_refusal_reason": true,
    "never_bypass_engine": true,
    "never_call_broker_directly_from_ui": true
  }
}
