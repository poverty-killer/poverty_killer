# ============================================
# POVERTY KILLER V1 - HARDENED ENVIRONMENT CONFIGURATION
# Copy this file to .env and fill in your values
# Never commit .env to version control
# For $20,000 account - 2026 Production Ready
# ============================================

# ============================================
# BROKER MODE
# ============================================
# Options: paper, live
BROKER_MODE=paper

# ============================================
# KRAKEN (CRYPTO)
# ============================================
# Get from: https://www.kraken.com/settings/api
KRAKEN_API_KEY=
KRAKEN_API_SECRET=

# ============================================
# ALPACA (US EQUITIES & ETFs)
# ============================================
# Get from: https://app.alpaca.markets/paper/dashboard/keys
# Use paper trading keys for testing
ALPACA_API_KEY=
ALPACA_API_SECRET=
ALPACA_PAPER=true

# ============================================
# INTERACTIVE BROKERS (FUTURES - FUTURE)
# ============================================
# TWS/Gateway must be running locally
IBKR_HOST=127.0.0.1
IBKR_PORT=7497
IBKR_CLIENT_ID=1

# ============================================
# TRADING PARAMETERS
# ============================================
INITIAL_CAPITAL=20000.0

# Symbol Universe (JSON array) - All markets
SYMBOL_UNIVERSE=["BTC/USD","ETH/USD","SOL/USD","AAPL","MSFT","NVDA","AMZN","META","GOOGL","SPY","QQQ","DIA","JPM","JNJ","WMT","ES","NQ","YM"]

# ============================================
# RISK PARAMETERS (HARD CAPS - NEVER BYPASSED)
# ============================================
# Global caps
MAX_LEVERAGE=2.0
MAX_TOTAL_EXPOSURE=0.70
MAX_SINGLE_STRATEGY_EXPOSURE=0.40
MAX_POSITIONS=5

# Drawdown protection
MAX_DAILY_DRAWDOWN=0.08
MAX_24H_DRAWDOWN=0.08
KILL_SWITCH_ENABLED=true

# Cash management
CASH_RESERVE_PERCENT=0.30

# Per-asset class limits (TOTAL = 1.0)
MAX_CRYPTO_EXPOSURE=0.15
MAX_EQUITY_EXPOSURE=0.35
MAX_ETF_EXPOSURE=0.30
MAX_FUTURE_EXPOSURE=0.20

# Per-symbol concentration
MAX_PER_SYMBOL_EXPOSURE=0.10

# Data safety
STALE_DATA_THRESHOLD_SECONDS=10
MAX_STRATEGY_SILENCE_SECONDS=60

# ============================================
# ASSET-CLASS SPECIFIC LEVERAGE
# ============================================
CRYPTO_LEVERAGE=1.0
EQUITY_LEVERAGE=1.0
FUTURE_LEVERAGE=2.0

# ============================================
# STRATEGY PARAMETERS
# ============================================
# Shadow-Front
WHALE_THRESHOLD_Z=2.0
SENTIMENT_VELOCITY_THRESHOLD=1.5
MIN_CONFIDENCE=0.6
WHALE_ZONE_TOLERANCE=0.02

# FLV (Fractal Liquidity Void)
FLV_MAX_HOLD_BARS=10
FLV_KELLY_MULTIPLIER=0.5
FLV_VOLUME_ANOMALY_THRESHOLD=3.0
FLV_SPREAD_EXPANSION_THRESHOLD=5.0

# Entropy Decoder
ENTROPY_WINDOW_SECONDS=60
ENTROPY_COLLAPSE_PERCENTILE=5
ENTROPY_MIN_SAMPLES=100

# Physical-On-Chain Validator
PHYSICAL_DATA_SOURCES_ENABLED=false
DIVERGENCE_THRESHOLD=0.5

# Convexity Switch
MOMENTUM_THRESHOLD=0.7
CARRY_THRESHOLD=0.3

# Hedging Flow Arbitrage
BASIS_SPIKE_THRESHOLD=2.0
HEDGE_UNWIND_WINDOW_HOURS=24

# Adaptive DC Optimizer
DC_MIN_THRESHOLD=0.002
DC_MAX_THRESHOLD=0.02

# Gamma-Front (Dark Pool)
DARK_POOL_ENABLED=true
OPTIONS_FLOW_ENABLED=false
DARK_POOL_VOLUME_THRESHOLD=5.0

# Sector Rotation
SECTOR_INFLOW_THRESHOLD=1.5

# ============================================
# STRATEGY TOGGLES
# ============================================
SHADOW_FRONT_ENABLED=true
FLV_ENABLED=true
ENTROPY_DECODER_ENABLED=true
PHYSICAL_ONCHAIN_ENABLED=true
CONVEXITY_SWITCH_ENABLED=true
HEDGING_FLOW_ENABLED=true
ADAPTIVE_DC_ENABLED=true
GAMMA_FRONT_ENABLED=true
SECTOR_ROTATION_ENABLED=true

# ============================================
# SIGMA RISK CONFIGURATION (Regime-Based Scaling)
# ============================================
# Trending regime multipliers
TRENDING_WHALE_THRESHOLD_MULTIPLIER=0.8
TRENDING_SENTIMENT_THRESHOLD_MULTIPLIER=0.7
TRENDING_CONFIDENCE_MULTIPLIER=1.2

# Ranging regime multipliers
RANGING_WHALE_THRESHOLD_MULTIPLIER=1.2
RANGING_SENTIMENT_THRESHOLD_MULTIPLIER=1.3
RANGING_CONFIDENCE_MULTIPLIER=0.8

# Crisis regime multipliers
CRISIS_WHALE_THRESHOLD_MULTIPLIER=1.5
CRISIS_SENTIMENT_THRESHOLD_MULTIPLIER=1.5
CRISIS_CONFIDENCE_MULTIPLIER=0.5

# ============================================
# DATA CONFIGURATION
# ============================================
MAX_CANDLES_PER_SYMBOL=1000
WEBSOCKET_RECONNECT_DELAY=5
WEBSOCKET_MAX_QUEUE_SIZE=10000
WEBSOCKET_PING_INTERVAL=30
POLLING_INTERVAL_SECONDS=1.0
FEATURE_WINDOW_SLOW=50
FEATURE_WINDOW_FAST=10

# ============================================
# EXECUTION CONFIGURATION (Paper Trading Realism)
# ============================================
LATENCY_BUFFER_MS=50
LATENCY_JITTER_MS=25
SLIPPAGE_MODEL_ENABLED=true
BASE_SLIPPAGE_BPS=1.0
MARKET_IMPACT_FACTOR=0.1
FEE_MODEL_ENABLED=true
TAKER_FEE_BPS=16.0
MAKER_FEE_BPS=8.0
MAX_ORDER_RETRIES=3
RETRY_DELAY_SECONDS=1.0

# ============================================
# SYSTEM PARAMETERS
# ============================================
# Logging levels: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
SNAPSHOT_INTERVAL_SECONDS=60
REPORT_INTERVAL_HOURS=24

# Control Mode: SAFE, NORMAL, MODERATE, AGGRESSIVE, CRISIS_OPPORTUNISTIC, CAPITAL_SECURE, EMERGENCY_HALT
CONTROL_MODE=NORMAL